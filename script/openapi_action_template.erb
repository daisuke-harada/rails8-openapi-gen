  # default action template
  # available vars: action (String), controller (String), path (String), method (String), serializer_class (String), example (String - Ruby literal)
  def <%= action %>
<% if serializer_class %>
  # This action calls the corresponding serializer (data supplied by serializer examples when nil).
  render json: <%= serializer_class %>.<%= action %>_response, status: :ok
<% else %>
  # No serializer available; return empty JSON
  render json: {}, status: :ok
<% end %>
  end
